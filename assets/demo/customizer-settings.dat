{
  "marbure_theme_options": {
    "site_layout": "wide",
    "container_width": 1200,
    "default_sidebar_position": "right",
    "sticky_header": true,
    "show_top_bar": true,
    "header_background_color": "#ffffff",
    "header_variant": "transparent",
    "header_cta_label": "Free Consultation",
    "header_cta_url": "/contact",
    "topbar_phone": "+1 (555) 100-2000",
    "topbar_email": "info@marburelaw.com",
    "footer_widget_columns": "4",
    "footer_copyright_text": "© {year} Marbure Law Firm. All rights reserved.",
    "show_back_to_top": true,
    "social_facebook": "https://facebook.com/marburelaw",
    "social_twitter": "https://twitter.com/marburelaw",
    "social_instagram": "https://instagram.com/marburelaw",
    "social_linkedin": "https://linkedin.com/company/marburelaw",
    "social_youtube": "",
    "body_font_family": "Inter",
    "body_font_size": 16,
    "body_font_weight": "400",
    "body_line_height": 1.75,
    "heading_font_family": "Playfair Display",
    "heading_font_weight": "700",
    "color_primary": "#0A1E3F",
    "color_secondary": "#CF9776",
    "color_accent": "#1A3A6B",
    "color_text": "#3D3D3D",
    "color_heading": "#0A1E3F",
    "color_bg": "#FFFFFF",
    "color_bg_alt": "#F8F8F8",
    "show_preloader": false,
    "show_back_to_top": true,
    "show_page_header": true,
    "page_header_overlay_color": "rgba(10,30,63,0.75)",
    "blog_archive_sidebar": "right",
    "blog_archive_columns": "2",
    "blog_single_sidebar": "right",
    "blog_excerpt_length": 30,
    "blog_show_date": true,
    "blog_show_category": true,
    "blog_show_author": true,
    "blog_show_author_box": true,
    "service_columns": "3",
    "portfolio_columns": "3",
    "portfolio_isotope": true,
    "team_columns": "3",
    "team_show_socials": true,
    "defer_js": true,
    "preconnect_fonts": true,
    "native_lazy_load": true,
    "output_image_dimensions": true,
    "prefooter_cta_enable": true,
    "prefooter_cta_heading": "Ready to Fight for Your Rights?",
    "prefooter_cta_subtext": "Schedule a free, no-obligation consultation with one of our experienced attorneys today.",
    "prefooter_cta_button_label": "Book a Free Call",
    "prefooter_cta_button_url": "/contact"
  }
}
