{
  "name": "marbure",
  "version": "1.0.0",
  "description": "Marbure — ThemeForest-quality Law Firm WordPress theme built on Underscores.",
  "author": "Sagar Patel",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "WordPress",
    "Theme",
    "Law Firm",
    "Legal",
    "Attorney"
  ],
  "devDependencies": {
    "@wordpress/scripts": "^27.0.0",
    "sass": "^1.77.0",
    "rtlcss": "^4.3.0",
    "dir-archiver": "^1.1.1"
  },
  "rtlcssConfig": {
    "options": {
      "autoRename": false,
      "autoRenameStrict": false,
      "blacklist": {},
      "clean": true,
      "greedy": false,
      "processUrls": false,
      "stringMap": []
    },
    "plugins": [],
    "map": false
  },
  "scripts": {
    "watch": "sass sass/style.scss:style.css --style=expanded --source-map --watch",
    "compile:css": "sass sass/style.scss:style.css --style=compressed --no-source-map",
    "compile:rtl": "rtlcss style.css style-rtl.css",
    "build": "npm run compile:css && npm run compile:rtl",
    "lint:scss": "wp-scripts lint-style 'sass/**/*.scss'",
    "lint:js": "wp-scripts lint-js 'js/src/**/*.js'",
    "bundle": "dir-archiver --src . --dest ../marbure.zip --exclude .DS_Store .git .gitattributes .gitignore node_modules vendor composer.phar package-lock.json sass *.map"
  }
}
